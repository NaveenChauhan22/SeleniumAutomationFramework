{
  "validCredentials": {
    "email": "${TEST_USER_EMAIL}",
    "password": "${TEST_USER_PASSWORD}"
  },
  "invalidEmailScenario": {
    "email": "not-a-valid-email",
    "password": "somepassword",
    "expectedEmailValidationError": "Enter a valid email"
  },
  "shortPasswordScenario": {
    "email": "abc@example.com",
    "password": "abc",
    "expectedPasswordValidationError": "Password must be at least 6 characters"
  },
  "emptyFieldsScenario": {
    "expectedEmailValidationError": "Enter a valid email",
    "expectedPasswordValidationError": "Password must be at least 6 characters"
  },
  "wrongPasswordScenario": {
    "email": "abc@example.com",
    "password": "wrongpassword123"
  },
  "unregisteredEmailScenario": {
    "email": "nonexistent@example.com",
    "password": "password123"
  },
  "apiAuth": {
    "endpoints": {
      "login": "/api/auth/login",
      "me": "/api/auth/me"
    },
    "assertions": {
      "tokenJsonPath": "token",
      "currentUserEmailJsonPath": "user.email"
    }
  },
  "assertions": {
    "loginPagePath": "/login"
  }
}