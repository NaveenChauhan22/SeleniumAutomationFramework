# Environment Variables for Test Credentials & Browser Configuration
# Copy this file to .env and fill in your actual test credentials
# IMPORTANT: .env is in .gitignore and should NEVER be committed to version control

# === TEST CREDENTIALS ===
# Valid test account credentials for login tests
TEST_USER_EMAIL=correctemail@example.com
TEST_USER_PASSWORD=correctpassword

# === BROWSER CONFIGURATION (Optional) ===
# Supported browsers: chrome, edge, firefox
# Default: chrome (from appsettings.json)
# Uncomment to override:
# TestSettings__Browser=chrome
# TestSettings__Headless=false
